{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "report-template",
  "title": "ReportTemplate",
  "description": "智能报告系统模板定义 Schema v2.0",
  "type": "object",
  "required": ["id", "type", "scene", "name", "parameters", "sections"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "模板唯一标识符",
      "pattern": "^[a-z0-9_]+$"
    },
    "type": {
      "type": "string",
      "description": "报告类型，如：设备健康评估"
    },
    "scene": {
      "type": "string",
      "description": "场景细分，如：总部、分部"
    },
    "name": {
      "type": "string",
      "description": "模板展示名称"
    },
    "parameters": {
      "type": "array",
      "description": "模板参数定义列表",
      "items": { "$ref": "#/$defs/Parameter" }
    },
    "sections": {
      "type": "array",
      "description": "报告章节树（顶层）",
      "items": { "$ref": "#/$defs/Section" }
    }
  },

  "$defs": {

    "Parameter": {
      "type": "object",
      "required": ["id", "label", "required", "input_type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "参数唯一标识，在内容中以 {param_id} 引用"
        },
        "label": {
          "type": "string",
          "description": "用户可读的参数名"
        },
        "required": {
          "type": "boolean",
          "description": "是否为必填参数"
        },
        "input_type": {
          "type": "string",
          "enum": ["free_text", "enum", "dynamic"],
          "description": "输入方式"
        },
        "interaction_mode": {
          "type": "string",
          "enum": ["form", "chat"],
          "default": "form",
          "description": "配置在该模板用于对话系统时，如何向用户发起该参数的追问：form(弹出可视化表单或控件组件)、chat(完全使用自然语言进行追问与识别)"
        },
        "multi": {
          "type": "boolean",
          "default": false,
          "description": "是否允许多值选择，true 时可作为 foreach 来源"
        },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "枚举选项，仅 input_type=enum 时有效"
        },
        "source": {
          "type": "string",
          "description": "动态选项来源，仅 input_type=dynamic 时有效"
        }
      }
    },

    "Section": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "章节标题"
        },
        "foreach": {
          "$ref": "#/$defs/Foreach",
          "description": "循环展开声明"
        },
        "outline": {
          "$ref": "#/$defs/OutlineBlueprint",
          "description": "大纲蓝图定义表（渲染前模板框架意图，作为 Agent 编译到底层 content 的输入来源）"
        },
        "content": {
          "$ref": "#/$defs/Content",
          "description": "叶节点内容，与 subsections 互斥"
        },
        "subsections": {
          "type": "array",
          "items": { "$ref": "#/$defs/Section" },
          "description": "子章节，与 content 互斥"
        }
      }
    },

    "Foreach": {
      "type": "object",
      "required": ["param", "as"],
      "additionalProperties": false,
      "properties": {
        "param": { "type": "string" },
        "as": { "type": "string" }
      }
    },

    "OutlineBlueprint": {
      "type": "object",
      "description": "报告大纲蓝图，包含带有组件占位符的富文本流（document）和对应的意图组件定义（blocks），作为大模型 Agent 编译底层配置的依据",
      "required": ["document", "blocks"],
      "additionalProperties": false,
      "properties": {
        "document": {
          "type": "string",
          "description": "富文本大纲连续描述，可包含对 block_id 的引用占位符（例如 '当前值为 {@metric_1}。\\n {@chart_1}'）"
        },
        "blocks": {
          "type": "array",
          "description": "对 document 中引用的占位符意图区块进行具体定义",
          "items": { "$ref": "#/$defs/OutlineBlock" }
        }
      }
    },

    "OutlineBlock": {
      "type": "object",
      "description": "大纲意图中的可变参数区块，对应 document 中的 {@id} 占位符。用于参数化意图描述，而非规定最终报告的展现形式。",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "区块唯一标识符，对应 document 中的 {@id} 占位语法"
        },
        "type": {
          "type": "string",
          "enum": ["indicator", "time_range", "scope", "threshold", "operator", "enum_select", "number", "boolean", "free_text", "param_ref"],
          "description": "意图参数类型：indicator(指标选择)、time_range(时间跨度)、scope(空间范围)、threshold(设定阈值,如80%)、operator(操作符,如大于/小于)、enum_select(通用枚举选择)、number(纯数值)、boolean(开关量)、free_text(自由文本)、param_ref(全局参数)"
        },
        "hint": {
          "type": "string",
          "description": "面向用户的 UI 提示语，说明该参数的作用和填写范围"
        },
        "default": {
          "type": "string",
          "description": "模板设计时预设的默认值（应与 value 对应，而非 label）"
        },
        "options": {
          "type": "array",
          "description": "供用户选择的选项集合，兼具 UI 显示与底层代码逻辑的映射关系",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {
              "label": {
                "type": "string",
                "description": "在蓝图上展示给用户看的人类可读语义翻译 (例如 '大于'、'出口压力')"
              },
              "value": {
                "type": "string",
                "description": "在交给后端组装 SQL 或表达式时使用的程序化机器码 (例如 '>', 'pressure_out')"
              }
            }
          }
        }
      }
    },

    "Content": {
      "type": "object",
      "description": "内容节点：数据获取与视图层平级解耦 (v2.0)",
      "required": ["presentation"],
      "additionalProperties": false,
      "properties": {
        "datasets": {
          "type": "array",
          "description": "局部数据池，按 DAG 拓扑执行",
          "items": { "$ref": "#/$defs/Dataset" }
        },
        "presentation": { "$ref": "#/$defs/Presentation" }
      }
    },

    "Dataset": {
      "type": "object",
      "required": ["id", "source"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "数据集全局唯一标识"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "前置依赖的 Dataset ID 列表"
        },
        "source": { "$ref": "#/$defs/Source" }
      }
    },

    "Source": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["sql", "nl2sql", "ai_synthesis"],
          "description": "数据获取方式"
        },
        "query": { "type": "string" },
        "key_col": { "type": "string" },
        "value_col": { "type": "string" },
        "description": { "type": "string" },
        "context": {
          "type": "object",
          "properties": {
            "refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "queries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "query"],
                "properties": {
                  "id": { "type": "string" },
                  "query": { "type": "string" }
                }
              }
            }
          }
        },
        "knowledge": {
          "type": "object",
          "properties": {
            "query_template": { "type": "string" },
            "params": {
              "type": "object",
              "properties": {
                "subject": { "type": "string" },
                "symptoms": { "type": "string" },
                "objective": { "type": "string" }
              }
            }
          }
        },
        "prompt": { "type": "string" }
      }
    },

    "Presentation": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "value", "chart", "simple_table", "composite_table"],
          "description": "呈现类型"
        },
        "template": { "type": "string" },
        "anchor": { "type": "string" },
        "chart_type": {
          "type": "string",
          "enum": ["bar", "line", "pie", "area", "scatter"]
        },
        "columns": { "type": "integer" },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/CompositeSection" }
        }
      }
    },

    "CompositeSection": {
      "type": "object",
      "required": ["layout"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "band": {
          "type": ["string", "null"]
        },
        "dataset_id": { "type": "string" },
        "layout": { "$ref": "#/$defs/Layout" }
      }
    },

    "Layout": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["kv_grid", "tabular"]
        },
        "cols_per_row": { "type": "integer" },
        "key_span": { "type": "integer" },
        "value_span": { "type": "integer" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key"],
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" },
              "col": { "type": "string" }
            }
          }
        },
        "headers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "span"],
            "properties": {
              "label": { "type": "string" },
              "span": { "type": "integer" },
              "repeat": { "type": "boolean" }
            }
          }
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "span"],
            "properties": {
              "field": { "type": "string" },
              "span": { "type": "integer" },
              "repeat": { "type": "boolean" }
            }
          }
        }
      }
    }

  }
}
